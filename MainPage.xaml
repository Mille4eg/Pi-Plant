<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Pi_Plant.MainPage"
    BackgroundColor="#EAF6F7">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="20">

            <Grid ColumnDefinitions="*,Auto">

                <VerticalStackLayout Grid.Column="0" Spacing="2">
                    <Label
                        Text="Pi-Plant"
                        FontSize="32"
                        FontAttributes="Bold"
                        TextColor="#103B4D"/>

                    <Label
                        Text="Your daily wellness companion"
                        FontSize="14"
                        TextColor="#5E8A92"/>
                </VerticalStackLayout>

                <VerticalStackLayout
                    Grid.Column="1"
                    Spacing="4"
                    HorizontalOptions="End">

                    <Image
                        Source="justpiplantlogo.png"
                        HeightRequest="60"
                        WidthRequest="60">
                        <Image.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Profile_Tapped"/>
                        </Image.GestureRecognizers>
                    </Image>

                    <Label
                        x:Name="HelloLabel"
                        Text="Hello, Flavor Text!"
                        FontSize="12"
                        TextColor="#5E8A92"
                        HorizontalOptions="Center">
                        <Label.GestureRecognizers>
                            <TapGestureRecognizer Tapped="Profile_Tapped"/>
                        </Label.GestureRecognizers>
                    </Label>

                </VerticalStackLayout>

            </Grid>

            <Frame
                CornerRadius="20"
                BackgroundColor="White"
                Padding="15">

                <VerticalStackLayout Spacing="15">

                    <Label
                        Text="BIOLOGICAL SEX"
                        FontAttributes="Bold"
                        TextColor="#5E8A92"/>

                    <HorizontalStackLayout Spacing="10">

                        <Button
                            x:Name="FemaleButton"
                            Text="♀ Female"
                            BackgroundColor="#DCECEC"
                            TextColor="#103B4D"
                            Clicked="FemaleButton_Clicked"/>

                        <Button
                            x:Name="MaleButton"
                            Text="♂ Male"
                            BackgroundColor="#DCECEC"
                            TextColor="#103B4D"
                            Clicked="MaleButton_Clicked"/>

                    </HorizontalStackLayout>

                    <Label
                        x:Name="GoalLabel"
                        Text="Daily Goal: 9 cups of water"
                        HorizontalOptions="Center"/>

                </VerticalStackLayout>

            </Frame>

            <Frame
                CornerRadius="20"
                BackgroundColor="White"
                Padding="20">

                <VerticalStackLayout Spacing="15">

                    <HorizontalStackLayout>

                        <Label
                            Text="💧 Water Intake"
                            FontSize="24"
                            FontAttributes="Bold"
                            HorizontalOptions="StartAndExpand"/>

                        <Label
                            x:Name="WaterCountLabel"
                            Text="0 / 9"
                            FontSize="22"
                            FontAttributes="Bold"/>

                    </HorizontalStackLayout>

                    <Label
                        x:Name="PlantEmojiLabel"
                        Text="🟫"
                        FontSize="100"
                        HorizontalOptions="Center"/>

                    <Label
                        x:Name="PlantStatusLabel"
                        Text="Add water to begin growing!"
                        HorizontalOptions="Center"
                        TextColor="#5E8A92"/>

                    <ProgressBar
                        x:Name="WaterProgressBar"
                        Progress="0"
                        ProgressColor="#46957D"/>

                    <Button
                        Text="💧 Drink a Cup"
                        BackgroundColor="#46957D"
                        TextColor="White"
                        Clicked="DrinkWater_Clicked"/>

                    <Button
                        Text="Remove Cup"
                        BackgroundColor="#DCECEC"
                        TextColor="#103B4D"
                        Clicked="RemoveWater_Clicked"/>

                </VerticalStackLayout>

            </Frame>

            <Frame
                CornerRadius="20"
                BackgroundColor="White"
                Padding="20">

                <VerticalStackLayout Spacing="15">

                    <Label
                        Text="👟 Daily Step Goal"
                        FontSize="24"
                        FontAttributes="Bold"
                        TextColor="#103B4D"/>

                    <Label
                        Text="Move the slider to find your suggested daily goal."
                        TextColor="#5E8A92"/>

                    <Grid ColumnDefinitions="*,Auto">

                        <Label
                            Text="Your Weight"
                            VerticalOptions="Center"/>

                        <Label
                            x:Name="WeightLabel"
                            Text="180 lbs"
                            Grid.Column="1"
                            FontAttributes="Bold"/>

                    </Grid>

                    <Slider
                        Minimum="50"
                        Maximum="300"
                        Value="180"
                        ValueChanged="WeightSlider_ValueChanged"/>

                    <Frame
                        BackgroundColor="#EAF6F7"
                        CornerRadius="15"
                        Padding="15">

                        <VerticalStackLayout>

                            <Label
                                Text="Suggested Daily Goal"
                                TextColor="#5E8A92"
                                HorizontalOptions="Center"/>

                            <Label
                                x:Name="StepGoalLabel"
                                Text="8,000 steps"
                                FontSize="28"
                                FontAttributes="Bold"
                                TextColor="#103B4D"
                                HorizontalOptions="Center"/>

                        </VerticalStackLayout>

                    </Frame>

                </VerticalStackLayout>

            </Frame>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>