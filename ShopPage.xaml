<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    x:Class="Pi_Plant.ShopPage"
    Title="Shop"
    BackgroundColor="#EAF6F7">

    <ScrollView>

        <VerticalStackLayout
            Padding="20"
            Spacing="20">

            <Label
                Text="Pi-Plant Shop"
                FontSize="30"
                FontAttributes="Bold"
                HorizontalOptions="Center"
                TextColor="#103B4D"/>

            <Frame
                CornerRadius="20"
                BackgroundColor="White"
                Padding="20">

                <VerticalStackLayout Spacing="12">

                    <Label
                        Text="Coming Soon!"
                        FontSize="26"
                        FontAttributes="Bold"
                        HorizontalOptions="Center"
                        TextColor="#46957D"/>

                    <Label
                        Text="The Pi-Plant shop is still under construction."
                        HorizontalTextAlignment="Center"
                        TextColor="#5E8A92"/>

                    <BoxView HeightRequest="1" Color="#DCECEC"/>

                    <Label Text="• Flower Seeds" FontSize="18"/>
                    <Label Text="• New Plant Pots" FontSize="18"/>
                    <Label Text="• Decorations" FontSize="18"/>
                    <Label Text="• Seasonal Plants" FontSize="18"/>

                </VerticalStackLayout>

            </Frame>

            <Button
                Text="Go to Account"
                BackgroundColor="#46957D"
                TextColor="White"
                Clicked="AccountButton_Clicked"/>

            <Button
                Text="Back Home"
                BackgroundColor="#DCECEC"
                TextColor="#103B4D"
                Clicked="HomeButton_Clicked"/>

        </VerticalStackLayout>

    </ScrollView>

</ContentPage>